# Bu dosyayı .env olarak kopyalayın ve kendi değerlerinizi girin
# cp .env.example .env

# Groq Console'dan (https://console.groq.com) alacağınız API anahtarı
GROQ_API_KEY=your_api_key_here

# Kullanılacak model adı (En iyi ve hızlı model: llama-3.3-70b-versatile)
DEEPDESK_MODEL=llama-3.3-70b-versatile

# Hafıza verilerinin saklanacağı klasör
DEEPDESK_MEMORY_DIR=.chroma_memory

# Planner Agent'ın üreteceği maksimum alt soru sayısı
DEEPDESK_MAX_SUBQUESTIONS=4
