# Bu dosyayı .env olarak kopyalayın ve kendi değerlerinizi girin
# cp .env.example .env

# Anthropic Console'dan (https://console.anthropic.com) alacağınız API anahtarı
ANTHROPIC_API_KEY=your_api_key_here

# Kullanılacak model adı (güncel liste: https://docs.claude.com/en/docs/about-claude/models)
DEEPDESK_MODEL=claude-3-5-sonnet-20241022

# Hafıza verilerinin saklanacağı klasör
DEEPDESK_MEMORY_DIR=.chroma_memory

# Planner Agent'ın üreteceği maksimum alt soru sayısı
DEEPDESK_MAX_SUBQUESTIONS=4
